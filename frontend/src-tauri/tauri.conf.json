{
  "$schema": "https://raw.githubusercontent.com/nicholasgasior/tauri-schema/refs/heads/main/tauri.conf.json",
  "productName": "CCBell Sound Generator",
  "version": "1.1.0",
  "identifier": "com.ccbell.soundgenerator",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CCBell Sound Generator",
        "width": 1280,
        "height": 900,
        "minWidth": 900,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["python3 (>= 3.11)", "python3-venv", "libsndfile1", "ffmpeg"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "python-sidecar",
          "cmd": "python3",
          "args": true
        },
        {
          "name": "pip",
          "cmd": "python3",
          "args": true
        },
        {
          "name": "uvicorn",
          "cmd": "uvicorn",
          "args": true
        }
      ]
    }
  }
}
